<Window x:Class="EventsDB.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вхід" Width="350"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="EventsDB - Вхід"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="Логін:" Margin="0,0,0,4"/>
        <TextBox   Grid.Row="2" x:Name="txtUsername" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Пароль:" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="txtPassword" Margin="0,0,0,0"/>

        <Button Grid.Row="5" x:Name="btnLogin" Content="Увійти"
                Margin="0,16,0,0" Height="32"
                Click="BtnLogin_Click"/>

        <TextBlock Grid.Row="6" x:Name="txtError"
                   Foreground="Red" TextWrapping="Wrap"
                   Margin="0,8,0,0" Visibility="Collapsed"/>
    </Grid>
</Window>