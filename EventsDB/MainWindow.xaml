<Window x:Class="EventsDB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Щоденник подій" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
            </Border.Effect>
            <DockPanel>
                <Button DockPanel.Dock="Bottom"
                x:Name="btnLogout" Content="Вийти"
                Background="#FF9800" Foreground="White"
                FontWeight="Bold" Padding="8"
                Click="BtnLogout_Click"/>
                <Separator DockPanel.Dock="Bottom" Margin="0,10"/>

                <StackPanel x:Name="pnlAdminControls">
                    <TextBlock Text="Керування записом" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <TextBlock Text="Час (ГГ:ХХ):" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtTime" Margin="0,5,0,10" Padding="4" ToolTip="Наприклад: 09:30"/>

                    <TextBlock Text="Дата (ММ.ДД):" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtDate" Margin="0,5,0,10" Padding="4" ToolTip="Наприклад: 12.25"/>

                    <TextBlock Text="Місце:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtLocation" Margin="0,5,0,10" Padding="4"/>

                    <TextBlock Text="Назва події:" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtName" Margin="0,5,0,20" Padding="4"/>

                    <Button x:Name="btnAdd" Content="Додати запис" Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,10" Click="BtnAdd_Click"/>
                    <Button x:Name="btnUpdate" Content="Оновити обраний" Background="#2196F3" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,10" Click="BtnUpdate_Click"/>
                    <Button Content="Очистити форму" Background="#9E9E9E" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,20" Click="BtnClear_Click"/>


                    <Button x:Name="btnDelete" Content="Видалити обраний" Background="#F44336" Foreground="White" FontWeight="Bold" Padding="8" Click="BtnDelete_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Text="Пошук:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbSearchType" Grid.Column="1" Width="100" Margin="0,0,5,0" SelectedIndex="0">
                        <ComboBoxItem Content="За назвою"/>
                        <ComboBoxItem Content="За часом"/>
                        <ComboBoxItem Content="За місцем"/>
                        <ComboBoxItem Content="За датою"/>
                    </ComboBox>
                    <TextBox x:Name="txtSearch" Grid.Column="2" Width="150" Margin="0,0,5,0" Padding="2" TextChanged="TxtSearch_TextChanged"/>
                    <Button Grid.Column="2" Content="✕" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,5,0" Click="BtnClearSearch_Click" ToolTip="Очистити пошук" Background="Transparent" BorderThickness="0"/>

                    <TextBlock Grid.Column="4" Text="Сортування:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="15,0,5,0"/>
                    <ComboBox x:Name="cmbSortType" Grid.Column="5" Width="140" SelectionChanged="CmbSortType_SelectionChanged">
                        <ComboBoxItem Content="За замовчуванням (ID)"/>
                        <ComboBoxItem Content="За часом"/>
                        <ComboBoxItem Content="За місцем (А→Я)"/>
                        <ComboBoxItem Content="За назвою (А→Я)"/>
                        <ComboBoxItem Content="За датою (зростання)"/>
                        <ComboBoxItem Content="За датою (спадання)"/>
                    </ComboBox>
                </Grid>
            </Border>

            <DataGrid x:Name="dgEvents" Grid.Row="1" AutoGenerateColumns="False" 
                      CanUserAddRows="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionChanged="DgEvents_SelectionChanged"
                      Background="White" RowHeight="30" AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Час" Binding="{Binding Time}" Width="70"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="70"/>
                    <DataGridTextColumn Header="Місце" Binding="{Binding Location}" Width="150"/>
                    <DataGridTextColumn Header="Назва події" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>