<Window x:Class="EventsDB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Щоденник подій" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
            </Border.Effect>
            <DockPanel>
                <!-- Вихід: Передаємо вікно як параметр команди через RelativeSource -->
                <Button DockPanel.Dock="Bottom"
                        x:Name="btnLogout" Content="Вийти"
                        Background="#FF9800" Foreground="White"
                        FontWeight="Bold" Padding="8"
                        Command="{Binding LogoutCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Separator DockPanel.Dock="Bottom" Margin="0,10"/>

                <Grid>
                    <!-- Панель для адміна (редагування) -->
                    <StackPanel x:Name="pnlAdminControls" Visibility="{Binding AdminControlsVisibility}">
                        <TextBlock Text="Керування записом" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <TextBlock Text="Час (ГГ:ХХ):" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtTime" Margin="0,5,0,10" Padding="4" ToolTip="Наприклад: 09:30"
                                 Text="{Binding Time, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Дата (ММ.ДД):" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtDate" Margin="0,5,0,10" Padding="4" ToolTip="Наприклад: 12.25"
                                 Text="{Binding Date, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Місце:" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtLocation" Margin="0,5,0,10" Padding="4"
                                 Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Назва події:" FontWeight="SemiBold"/>
                        <TextBox x:Name="txtName" Margin="0,5,0,20" Padding="4"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button x:Name="btnAdd" Content="Додати запис" Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,10" 
                                Command="{Binding AddCommand}"/>
                        <Button x:Name="btnUpdate" Content="Оновити обраний" Background="#2196F3" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,10" 
                                Command="{Binding UpdateCommand}"/>
                        <Button Content="Очистити форму" Background="#9E9E9E" Foreground="White" FontWeight="Bold" Padding="8" Margin="0,0,0,20" 
                                Command="{Binding ClearCommand}"/>

                        <Button x:Name="btnDelete" Content="Видалити обраний" Background="#F44336" Foreground="White" FontWeight="Bold" Padding="8" 
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>

                    <!-- Панель для в'ювера (відомості про користувача) -->
                    <StackPanel x:Name="pnlViewerInfo" Visibility="{Binding ViewerInfoVisibility}" Background="White">
                        <TextBlock Text="Кабінет користувача" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <TextBlock Text="Користувач:" FontWeight="SemiBold" Foreground="#757575"/>
                        <TextBlock x:Name="lblUsername" FontSize="16" FontWeight="Bold" Margin="0,5,0,15"
                                   Text="{Binding CurrentUsername}"/>

                        <TextBlock Text="Рівень доступу:" FontWeight="SemiBold" Foreground="#757575"/>
                        <TextBlock Text="Тільки перегляд (Viewer)" FontSize="14" FontWeight="Bold" Foreground="#FF9800" Margin="0,5,0,25"/>

                        <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="10" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Доступні можливості:" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="• Пошук подій за параметрами" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="• Сортування таблиці" Margin="0,3" TextWrapping="Wrap"/>
                                <TextBlock Text="• Перегляд списку без редагування" Margin="0,3" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Пошук:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbSearchType" Grid.Column="1" Width="100" Margin="0,0,5,0" 
                              SelectedIndex="{Binding SelectedSearchType, Mode=TwoWay}">
                        <ComboBoxItem Content="За назвою"/>
                        <ComboBoxItem Content="За часом"/>
                        <ComboBoxItem Content="За місцем"/>
                        <ComboBoxItem Content="За датою"/>
                    </ComboBox>

                    <TextBox x:Name="txtSearch" Grid.Column="2" Width="150" Margin="0,0,5,0" Padding="2" 
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="2" Content="✕" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,5,0" 
                            ToolTip="Очистити пошук" Background="Transparent" BorderThickness="0"
                            Command="{Binding ClearSearchCommand}"/>

                    <TextBlock Grid.Column="4" Text="Сортування:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="15,0,5,0"/>
                    <ComboBox x:Name="cmbSortType" Grid.Column="5" Width="140" 
                              SelectedIndex="{Binding SelectedSortType, Mode=TwoWay}">
                        <ComboBoxItem Content="За замовчуванням (ID)"/>
                        <ComboBoxItem Content="За часом"/>
                        <ComboBoxItem Content="За місцем (А→Я)"/>
                        <ComboBoxItem Content="За назвою (А→Я)"/>
                        <ComboBoxItem Content="За датою (зростання)"/>
                        <ComboBoxItem Content="За датою (спадання)"/>
                    </ComboBox>
                </Grid>
            </Border>

            <DataGrid x:Name="dgEvents" Grid.Row="1" AutoGenerateColumns="False" 
                      CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" 
                      Background="White" RowHeight="30" AlternatingRowBackground="#F9F9F9"
                      ItemsSource="{Binding Records}"
                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Час" Binding="{Binding Time}" Width="70"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="70"/>
                    <DataGridTextColumn Header="Місце" Binding="{Binding Location}" Width="150"/>
                    <DataGridTextColumn Header="Назва події" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>